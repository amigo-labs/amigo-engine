(
    name: "stranger_things",
    checkpoint: "pixel_art_xl_v1.safetensors",
    lora: Some(("pixel_art_16bit.safetensors", 0.65)),
    palette: [
        "#1a0a2e", "#2e0854", "#6a0dad", "#ff1493", "#ff6ec7",
        "#00ffff", "#ff4500", "#ffd700", "#1a1a2e", "#e0e0e0",
    ],
    prompt_prefix: "pixel art, 16-bit style, 1980s retro, neon, synthwave, upside down,",
    negative_prompt: "realistic, 3d, smooth, anti-aliased, gradient, blurry, modern, minimal",
    default_size: (32, 32),
    steps: 20,
    cfg_scale: 7.0,
    post_processing: (
        palette_clamp: true,
        remove_anti_aliasing: true,
        add_outline: true,
        outline_color: "#1a0a2e",
        outline_mode: Outer,
        cleanup_transparency: true,
        tile_edge_check: false,
    ),
    reference_images: [],
)

(
    name: "matrix",
    checkpoint: "pixel_art_xl_v1.safetensors",
    lora: None,
    palette: [
        "#000000", "#001a00", "#003300", "#006600", "#00cc00",
        "#00ff00", "#0a0a0a", "#1a1a1a", "#2a2a2a", "#00ff41",
    ],
    prompt_prefix: "pixel art, 16-bit style, cyberpunk dark, green on black, neon,",
    negative_prompt: "realistic, 3d, smooth, anti-aliased, gradient, blurry, colorful, bright",

{
  "1": {
    "class_type": "LoadImage",
    "inputs": { "image": "{{input_image}}" }
  },
  "2": {
    "class_type": "ImageScaleBy",
    "inputs": { "image": ["1", 0], "upscale_method": "nearest-exact", "scale_by": "{{factor}}" }
  },
  "3": {
    "class_type": "SaveImage",
    "inputs": { "images": ["2", 0], "filename_prefix": "{{filename_prefix}}" }
  }
}
